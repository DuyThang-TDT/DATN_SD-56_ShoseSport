@{
    ViewData["Title"] = "Liên hệ";
}

<section class="py-20 bg-gray-100">
    <div class="max-w-4xl mx-auto px-6">
        <h1 class="text-4xl font-bold text-center mb-10">
            Liên hệ ShoesSport
        </h1>

        <div class="grid md:grid-cols-2 gap-10">
            <div>
                <h3 class="text-xl font-semibold mb-4">Thông tin cửa hàng</h3>
                <p class="mb-2">📍 Hà Nội, Việt Nam</p>
                <p class="mb-2">📞 0123 456 789</p>
                <p class="mb-2">📧 ShoesSport@gmail.com</p>
            </div>

            <div>
                <h3 class="text-xl font-semibold mb-4">Gửi tin nhắn</h3>
    
                <form>
                    <input type="text" placeholder="Họ và tên"
                           class="w-full border rounded px-4 py-2 mb-4" />

                    <input type="email" placeholder="Email"
                           class="w-full border rounded px-4 py-2 mb-4" />

                    <textarea placeholder="Nội dung"
                              class="w-full border rounded px-4 py-2 mb-4"
                              rows="4"></textarea>

                    <button type="submit"
                            class="px-6 py-3 bg-black text-white rounded hover:bg-gray-800">
                        Gửi liên hệ
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
